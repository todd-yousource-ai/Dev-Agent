from __future__ import annotations

import hashlib
import struct
from dataclasses import dataclass, field
from enum import Enum, auto
from typing import Final, Sequence

# === Constants derived from TRD specifications ===

# TRD-10-Document-Store: 100 chunks × 768 dims × 4 bytes = ~300KB per project
MAX_CHUNKS_PER_PROJECT: Final[int] = 100
EMBEDDING_DIMENSIONS: Final[int] = 768
EMBEDDING_BYTE_WIDTH: Final[int] = 4  # float32
EXPECTED_EMBEDDING_BYTES: Final[int] = EMBEDDING_DIMENSIONS * EMBEDDING_BYTE_WIDTH  # 3072 bytes

# TRD-3-Build-Pipeline: 16000 comfortably covers 35 PRDs with dependency descriptions
# 8192 was too small — caused truncated PRD lists in v38.37
TOKEN_BUDGET_DEFAULT: Final[int] = 16_000
TOKEN_BUDGET_MIN: Final[int] = 8_193  # Must exceed the known-bad 8192 threshold
TOKEN_BUDGET_MAX: Final[int] = 128_000  # gpt-4o context: 128k tokens (~512k chars)

# Approximate chars-per-token ratio for budget estimation
CHARS_PER_TOKEN_ESTIMATE: Final[float] = 4.0


class ChunkManagerError(Exception):
    """Base error for all ChunkManager failures. Always includes context."""
    pass


class TokenBudgetExceededError(ChunkManagerError):
